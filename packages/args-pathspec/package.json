{
  "name": "@simple-git/args-pathspec",
  "version": "1.0.3",
  "publish": {
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  },
  "main": "./index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json",
    "test": "vitest run",
    "build:pkg": "tsx ../../devtools/package-json ./packages/args-pathspec/package.json",
    "prepublishOnly": "yarn build:pkg"
  },
  "devDependencies": {
    "vite": "^8.0.5",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "git",
    "source control",
    "vcs",
    "simple-git"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steveukx/git-js.git",
    "directory": "packages/args-pathspec"
  },
  "publishConfig": {
    "access": "public"
  }
}
